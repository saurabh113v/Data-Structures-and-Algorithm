class Solution {
    public boolean check(int[] nums) {
         int breakCount = 0;
        int arrayLength = nums.length;
        for (int i = 0; i < arrayLength; i++) {
            int nextIndex = (i + 1) % arrayLength;
            if (nums[i] > nums[nextIndex]) {
                breakCount++;
            }
        }
        return breakCount <= 1;
    }
}
