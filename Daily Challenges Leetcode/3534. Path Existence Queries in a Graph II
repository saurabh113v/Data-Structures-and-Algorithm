import java.util.Arrays;

class Solution {
    public int[] pathExistenceQueries(int n, int[] nums, int maxDiff, int[][] queries) {
        // 1. Sort the node indices based on their values in nums
        Integer[] sortedIndices = new Integer[n];
        for (int i = 0; i < n; i++) {
            sortedIndices[i] = i;
        }
        Arrays.sort(sortedIndices, (a, b) -> Integer.compare(nums[a], nums[b]));

        // Record the position of each original node in the sorted array
        int[] sortedPos = new int[n];
        for (int i = 0; i < n; i++) {
            sortedPos[sortedIndices[i]] = i;
        }

        // 2. Use a two-pointer approach to find the furthest reachable node to the right
        int[] directParent = new int[n];
        int right = 0;
        for (int left = 0; left < n; left++) {
            while (right < n && nums[sortedIndices[right]] - nums[sortedIndices[left]] <= maxDiff) {
                right++;
            }
            // right - 1 is the furthest index we can reach from 'left'
            directParent[left] = right - 1;
        }

        // 3. Build the binary lifting table
        int LOG = (int) (Math.log(n) / Math.log(2)) + 1;
        int[][] up = new int[n][LOG];

        for (int i = 0; i < n; i++) {
            up[i][0] = directParent[i];
        }

        for (int j = 1; j < LOG; j++) {
            for (int i = 0; i < n; i++) {
                up[i][j] = up[up[i][j - 1]][j - 1];
            }
        }

        // 4. Process each query
        int[] answer = new int[queries.length];
        for (int q = 0; q < queries.length; q++) {
            int u = queries[q][0];
            int v = queries[q][1];

            int posU = sortedPos[u];
            int posV = sortedPos[v];

            if (posU == posV) {
                answer[q] = 0;
                continue;
            }

            // Ensure posU is always the smaller value (moving left to right)
            if (posU > posV) {
                int temp = posU;
                posU = posV;
                posV = temp;
            }

            // If the immediate jump from posU can already reach or overshoot posV
            if (directParent[posU] >= posV) {
                answer[q] = 1;
                continue;
            }

            // Lift posU as far as possible such that its next step still cannot reach posV
            int steps = 0;
            for (int j = LOG - 1; j >= 0; j--) {
                int nxt = up[posU][j];
                if (directParent[nxt] < posV) {
                    posU = nxt;
                    steps += (1 << j);
                }
            }
            posU = directParent[posU];
            steps++;
            if (directParent[posU] >= posV) {
                answer[q] = steps + 1;
            } else {
                answer[q] = -1;
            }
        }

        return answer;
    }
}
