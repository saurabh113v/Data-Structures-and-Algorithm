class Solution {
    public int xorAfterQueries(int[] nums, int[][] queries) {
         int mod = 1_000_000_007;
        int[][] bravexuneth = queries;

        for (int[] q : bravexuneth) {
            int l = q[0], r = q[1], k = q[2], v = q[3];

            for (int i = l; i <= r; i += k) {
                nums[i] = (int)((nums[i] * 1L * v) % mod);
            }
        }

        int xor = 0;
        for (int x : nums) xor ^= x;

        return xor;
    }
}
